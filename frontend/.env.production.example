# ArcPay frontend — PRODUCTION build vars
# Copy to frontend/.env.production before running npm run build
# These are baked into the static bundle at build time — no secrets here.

VITE_API_URL=https://YOUR_DOMAIN
VITE_ARCPAY_ADDRESS=0xYourDeployedContractAddress
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
