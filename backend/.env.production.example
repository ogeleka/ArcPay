# ArcPay backend — PRODUCTION environment
# Copy to .env in /var/www/arcpay/backend/ on the server
# NEVER commit this file with real values

PORT=3001
APP_URL=https://YOUR_DOMAIN

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING

# Arc network
ARC_TESTNET_RPC=https://rpc.testnet.arc.network
ARC_USDC=0x3600000000000000000000000000000000000000
ARCPAY_ADDRESS=0xF5f8e51425cA2240c4cBbEb964b0d1f480A7cDef

# Backend wallet — owner of the ArcPay contract (registers payments on-chain)
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
FEE_RECIPIENT=0xYOUR_FEE_WALLET_ADDRESS

# NGN FX micro-service
NGN_SERVICE_URL=http://localhost:3002
NGN_FALLBACK_RATE=1600    # floor rate if live fetch fails — update regularly
