# ArcPay backend — copy to .env and fill in.
#
# Storage is SQLite (better-sqlite3). The database file is created automatically
# at backend/arcpay.db on first run — there is no DATABASE_URL to configure.

PORT=3001
NODE_ENV=development

# URLs
APP_URL=http://localhost:3000           # dashboard + hosted checkout base (used in payment links)
NGN_SERVICE_URL=http://localhost:3002   # FX micro-service (the ngn/ process)
STORE_URL=http://localhost:3100         # optional demo store base

# Auth — generate with: openssl rand -hex 48
JWT_SECRET=replace-with-a-long-random-string

# Arc testnet + contract
ARC_TESTNET_RPC=https://rpc.testnet.arc.network
ARC_USDC=0x3600000000000000000000000000000000000000
ARCPAY_ADDRESS=0xF5f8e51425cA2240c4cBbEb964b0d1f480A7cDef

# Backend signer: the ArcPay contract owner key that registers payments on-chain.
# Use a dedicated testnet key. Never commit the real value.
PRIVATE_KEY=0xyour_testnet_private_key
