# ArcPay credentials — get these from the ArcPay dashboard after signing up
ARCPAY_API_KEY=your_api_key_here
ARCPAY_WEBHOOK_SECRET=your_webhook_secret_here

# Where ArcPay backend is running
# Local dev:  http://localhost:3001
# Production: https://arc.ogsnap.online
ARCPAY_URL=https://arc.ogsnap.online

# Where Footie is running (used to build callback_url sent to ArcPay)
# Local + ngrok: https://your-ngrok-id.ngrok.io
# Production:    https://your-footie-domain.com
STORE_URL=http://localhost:3100

# Port this server listens on
PORT=3100

# Optional — ArcPay contract address, used for the "View on ArcScan" explorer
# link on the live payments dashboard. Defaults to the testnet contract.
# ARCPAY_ADDRESS=0xF5f8e51425cA2240c4cBbEb964b0d1f480A7cDef
